{
  "name": "cstalk-desktop",
  "version": "1.2.4",
  "private": true,
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jin-Ra-Men/Enterprise-Collaboration-Hub-ECH-.git"
  },
  "scripts": {
    "prebuild:win": "node scripts/generate-icon-ico.mjs",
    "icon:build": "node scripts/build-desktop-icon.mjs && node scripts/generate-icon-ico.mjs",
    "start": "electron .",
    "build:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": ">=20.0.0",
    "electron-builder": "latest",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.cstalk.desktop",
    "productName": "CSTalk",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "artifactName": "CSTalk-Setup-${version}.${ext}",
      "icon": "assets/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Jin-Ra-Men",
        "repo": "Enterprise-Collaboration-Hub-ECH-"
      }
    ],
    "nsis": {
      "perMachine": true,
      "allowElevation": true,
      "include": "nsis/installer.nsh"
    }
  }
}
