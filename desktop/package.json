{
  "name": "ech-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jin-Ra-Men/Enterprise-Collaboration-Hub-ECH-.git"
  },
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win nsis --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": ">=20.0.0",
    "electron-builder": "latest"
  },
  "build": {
    "appId": "com.ech.desktop",
    "productName": "ECH",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      {
        "from": "assets",
        "to": "assets",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asar": true,
    "win": {
      "target": "nsis",
      "artifactName": "ECH-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Jin-Ra-Men",
        "repo": "Enterprise-Collaboration-Hub-ECH-"
      }
    ]
  }
}
