# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ech
DB_USER=ech_user
DB_PASSWORD=ech_password

# Spring
SPRING_PORT=8080

# Realtime Server
SOCKET_PORT=3001
# listen 주소(기본 0.0.0.0 — realtime/src/server.js)
# SOCKET_HOST=0.0.0.0
# Realtime: 메시지 본문 최대 길이(Backend 메시지 API 4000자와 맞출 것)
# MAX_MESSAGE_BODY_LENGTH=4000
# Realtime / 공통 DB 풀·타임아웃 (Realtime pg Pool)
# DB_POOL_MAX=10
# DB_POOL_IDLE_MS=30000
# DB_POOL_CONNECT_TIMEOUT_MS=10000

# Backend Hikari (Spring은 DB_POOL_MAX, DB_POOL_CONNECT_TIMEOUT_MS 재사용 가능)
# DB_POOL_MAX=10
# DB_POOL_CONNECT_TIMEOUT_MS=30000

# JWT 인증
# 운영 환경에서는 반드시 32자 이상의 무작위 값으로 교체할 것 (예: openssl rand -base64 32)
JWT_SECRET=ECH-dev-jwt-secret-key-change-in-prod
JWT_EXPIRATION_MS=28800000

# 릴리즈 파일 업로드 설정
MAX_UPLOAD_SIZE=500MB
MAX_REQUEST_SIZE=500MB
APP_RELEASES_DIR=./releases
# 첨부파일 저장 기본 경로 (절대 경로 권장, DB 설정으로 재기동 없이 변경 가능)
FILE_STORAGE_DIR=D:/testStorage
# 토큰 유효시간(ms). 기본 8시간 = 28800000
# JWT_EXPIRATION_MS=28800000
